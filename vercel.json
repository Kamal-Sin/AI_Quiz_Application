{
  "version": 2,
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://aiquizapplication-production.up.railway.app/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "env": {
    "REACT_APP_API_URL": "https://aiquizapplication-production.up.railway.app"
  }
}
